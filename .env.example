# LLM — Ollama on the host is the default
# Native uv / host process: http://localhost:11434
# Compose (Podman):          http://host.containers.internal:11434
# Compose (Docker Desktop):  http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Monitor pipeline — fast, reasoning OFF
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=512

# Advisor mode — fast defaults (set REASONING=true for deeper but slower replies)
OLLAMA_ADVISOR_NUM_CTX=6144
OLLAMA_ADVISOR_NUM_PREDICT=1024
OLLAMA_ADVISOR_REASONING=false

# Providers: ollama (default, host) | anthropic | openai | vllm
# Leave empty to inherit PIA_LLM_PROVIDER. Split example:
#   PIA_LLM_MONITOR_PROVIDER=ollama
#   PIA_LLM_ADVISOR_PROVIDER=anthropic
# vLLM / OpenAI-compatible (Compose gpu or remote):
#   PIA_LLM_PROVIDER=vllm
#   OPENAI_BASE_URL=http://vllm:8000/v1   # or LLM_BASE_URL=
#   OPENAI_MODEL=Qwen/Qwen3-8B           # or VLLM_MODEL=
#   OPENAI_API_KEY=not-needed
PIA_LLM_PROVIDER=ollama
PIA_LLM_MONITOR_PROVIDER=
PIA_LLM_ADVISOR_PROVIDER=

# Anthropic (when provider=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible (OpenAI, Azure-style proxies, vLLM)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o
# Phase 5 aliases (optional) — mapped onto OPENAI_* when set
# LLM_BASE_URL=http://vllm:8000/v1
# VLLM_MODEL=Qwen/Qwen3-8B

# Telegram
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=your@email.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=your@email.com

# News — watchlist-specific Google News feed is added automatically at runtime
RSS_FEEDS=https://feeds.content.dowjones.io/public/rss/mw_topstories,https://feeds.bbci.co.uk/news/business/rss.xml,https://news.google.com/rss/search?q=stock+market&hl=en-US&gl=US&ceid=US:en

# Behaviour
TIMEZONE=Europe/Rome
SKIP_LOW_CONFIDENCE=true
MAX_TICKERS_PER_NOTIFICATION=10
MAX_NEWS_HEADLINES_PER_TICKER=5
MAX_NEWS_HEADLINES_TOTAL=20
EMAIL_ENABLED=false
LOG_LEVEL=INFO
LOG_TO_CONSOLE=false
ADVISOR_STALE_STATE_HOURS=2
ADVISOR_NEWS_WINDOW_HOURS=48
ADVISOR_NEWS_HEADLINES_PER_TICKER=3

# Phase 3 — Advisor production
ADVISOR_HISTORY_MAX_TURNS=20
ADVISOR_FETCH_QUOTES=true
ADVISOR_FETCH_FUNDAMENTALS=false
ADVISOR_ADHOC_ANALYSIS=false
ADVISOR_ADHOC_MAX_TICKERS=3
ADVISOR_SCAN_ENABLED=false
ADVISOR_SCAN_MAX_TICKERS=150
ADVISOR_SCAN_CONCURRENCY=12
ADVISOR_SCAN_UNIVERSE_PATH=data/advisor_scan_universe.yaml
PROACTIVE_BRIEF_ENABLED=false
PROACTIVE_BRIEF_VIA=telegram
PROACTIVE_BRIEF_SKIP_IF_NOTIFY=false

# Phase 4 — web UI (uv run pia-web → http://127.0.0.1:8765)
PIA_WEB_HOST=127.0.0.1
PIA_WEB_PORT=8765
PIA_WEB_TOKEN=

# In-process Monitor schedule inside pia-web / pia-bot (08:00 / 13:00 / 17:30 TIMEZONE).
# Set false when using K8s CronJobs or Compose --profile schedule (Ofelia).
PIA_MONITOR_SCHEDULER=true

# OpenTelemetry (Aspire Dashboard — see deploy/otel/README.md)
PIA_OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:18889
OTEL_SERVICE_NAME=pia
